# Скопируй в .env и подставь свои значения.
# ВАЖНО: VITE_*-переменные вшиваются в клиентский бандл при сборке,
# поэтому ключ будет виден в JS. Это нормально для локального/личного
# использования, но не публикуй такую сборку с реальным ключом.

VITE_HYDRUS_URL=http://localhost:45869
VITE_HYDRUS_KEY=
